    "jsdom": "^29.1.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.9.4",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.3",
